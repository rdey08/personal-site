# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
desktop.ini
Thumbs.db
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local planning and AI-agent docs (kept out of the public repo)
PLAN.md
CHECKLIST.md
CLAUDE.md
AGENTS.md

# original photos/documents (may contain EXIF/PII) — only the optimized,
# metadata-stripped copies in public/images are committed
/assets-src/

# belt-and-braces: never commit a stray PDF dropped in the repo root
/*.pdf
